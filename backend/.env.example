# Copy to `backend/.env` for local runs. Values are illustrative only.
JWT_SECRET=change-me-use-at-least-32-characters-long!!
JWT_EXPIRES_IN=2h
MONGODB_URI=mongodb://127.0.0.1:27017/zuggernaut_dev
# When the SPA runs on another origin than the API, set comma-separated origins:
# FRONTEND_ORIGIN=https://your-app.web.app
# Toggle secure cookie flag (local http dev often wants false):
# COOKIE_SECURE=false
